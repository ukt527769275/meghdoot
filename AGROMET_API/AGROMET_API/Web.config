<configuration>
  <connectionStrings>
    <add name="db_connection" connectionString=""/>
  </connectionStrings>
  <appSettings>
    <!-- DEV -->
    <add key="GoogleTransalateKey" value="value"/>
    <add key="AccountName" value="agrometstorageacc"/>
    <add key="AccountKey" value=""/>
    <add key="ImageContainerName" value="image"/>
    <add key="ThumbNailContainerName" value="imagethumbnail"/>
    <add key="AudioContainerName" value="audio"/>
    <add key="VideoContainerName" value="video"/>
    <add key="DocumentContainerName" value="document"/>
    <add key="StorageConnectionString" value=""/>
    <add key="NotificationUrl" value="https://fcm.googleapis.com/fcm/send"/>
    <add key="AuthorizationKey" value=""/>
    <add key="SenderKey" value=""/>
    <add key="TimeOutValue" value="30"/>
    <!-- time out values in minutes-->
    <!--<add key="BaseURL" value="http://agromet-dev.azurewebsites.net/API" />-->
    <add key="BaseURL" value="http://meghdoot-app.tropmet.res.in:83"/>
    <add key="ProfileImageUrl" value="http://meghdoot-app.tropmet.res.in:83/UserProfileImages/"/>
    <add key="ExcelFile" value="F:\State.xlsx"/>
    <!--BEGIN SMS SETTINGS-->
    <add key="smsuserName" value="value"/>
    <add key="smsPassword" value="value"/>
    <add key="smsSenderID" value="value"/>
    <!--IMD URl-->
    <add key="DW" value="http://agromet.imd.gov.in/index.php/gfs_data/weather_forecast/"/>
    <add key="BW" value="http://agromet.imd.gov.in/index.php/download_block/download_block_data"/>
    <add key="AD" value="http://agromet.imd.gov.in/index.php/api/advisory_service/district_advisory/"/>
    <!--<add key="AD_NEW" value="http://agromet.imd.gov.in/index.php/api/Advisory_service/test_advisory/" /> -->
    <!-- need to apend /yyyy-mm-dd/stationId-->
    <!--<add key="AD_NEW" value="https://agromet.imd.gov.in/index.php/api/Advisory_service/demo_advisory/" /> -->
    <!-- need to apend /yyyy-mm-dd/stationId-->
    <!--<add key="AD_NEW" value="https://agromet.imd.gov.in/index.php/api/Advisory_service/aasd_district_advisory/" /> -->
    <!-- need to apend /yyyy-mm-dd/stationId-->
    <add key="AD_NEWDistrict" value="https://agromet.imd.gov.in/index.php/api/Advisory_service/aasd_district_advisory/"/>
    <add key="AD_NEW" value="https://agromet.imd.gov.in/index.php/api/Advisory_service/aasd_block_advisory/"/>
    <add key="AD_NEWASD" value="https://agromet.imd.gov.in/index.php/api/Advisory_service/aasd_asd_advisory/"/>
    <add key="FORCAST_KEY" value="https://agromet.imd.gov.in/index.php/api/advisory_service/m_blockfcst/"/>
    <add key="FORECAST_VA_KEY" value="https://agromet.imd.gov.in/index.php/api/advisory_service/m_va_blockfcst/"/>
    <add key="MasterCrops" value="http://agromet.imd.gov.in/index.php/api/advisory_service/crop_data/"/>
    <add key="PastWeather" value="https://www.imdagrimet.gov.in/weatherdata/KisanSuvidhaDataDownload.php?date="/>
    <!--yyyy-mm-dd-->
    <add key="DistrictWarning" value="ftp://icrisat@103.251.186.40/Agromet_Mobile_App_Data/district_warnings_now.csv"/>
    <add key="DistrictNowCast" value="ftp://icrisat@103.251.186.40/Agromet_Mobile_App_Data/Districtwise_Nowcast_now.csv"/>
    <add key="IsEnabledASDCrop" value="true"/>
    <add key="IsEnabledASDWeather" value="true"/>
    <add key="IsEnabledVAWeather" value="false"/>
    <add key="webpages:Version" value="3.0.0.0"/>
    <add key="webpages:Enabled" value="false"/>
    <add key="ClientValidationEnabled" value="true"/>
    <add key="UnobtrusiveJavaScriptEnabled" value="true"/>
    <add key="IsReRunFlow" value="True"/>
    <!-- make sure this will false in production mode this will be enable when manully run flow-->
    <add key="ReRunDate" value="2023-03-21"/>
  </appSettings>
  <!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
  <system.web>
    <compilation targetFramework="4.8" debug="true"/>
    <httpRuntime targetFramework="4.6.1"/>
    <httpModules>
      <add name="ApplicationInsightsWebTracking" type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web"/>
    </httpModules>
  </system.web>
  <system.webServer>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0"/>
      <remove name="OPTIONSVerbHandler"/>
      <remove name="TRACEVerbHandler"/>
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0"/>
    </handlers>
    <modules>
      <remove name="TelemetryCorrelationHttpModule"/>
      <add name="TelemetryCorrelationHttpModule" type="Microsoft.AspNet.TelemetryCorrelation.TelemetryCorrelationHttpModule, Microsoft.AspNet.TelemetryCorrelation" preCondition="integratedMode,managedHandler"/>
      <remove name="ApplicationInsightsWebTracking"/>
      <add name="ApplicationInsightsWebTracking" type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web" preCondition="managedHandler"/>
    </modules>
    <validation validateIntegratedModeConfiguration="false"/>
  </system.webServer>
