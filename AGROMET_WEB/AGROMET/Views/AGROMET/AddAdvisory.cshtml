@section scripts {
    <script>
    var app = angular.module("addCropAdvisory", []);
    app.controller("AddCropAdvisoryController", function ($scope, $http) {
        $scope.State = [];
        $scope.District = [];
        $scope.Block = [];
        $scope.Crop = [];
        $scope.Language = [];
        $scope.GetState = function (TypeOfRole,StateID) {
            $http({
                method: 'POST',
                url: '@Url.Action("GetStateList", "AGROMET")',
                headers: {
                    'Content-Type': "Application/Json"
                },
                data: { TypeOfRole: TypeOfRole, LanguageName: "@LanguageName", StateID: StateID }
                }).then(function (response) {
                    $scope.State = response.data;
                    //var item = { StateID: 0, StateName: "--Select--", LanguageType: null, RefreshDateTime: "" }
                    //$scope.State.splice(0, 0, item);
                    $scope.SelectedState = $scope.State[0];
                },
                function (response) {
                    alert("No result found");
                });
        }
        $scope.GetDistrict = function (TypeOfRole,StateID) {
            $http({
                method: 'POST',
                url: '@Url.Action("GetDistrictList", "AGROMET")',
                headers: {
                    'Content-Type': "Application/Json"
                },
                data: { TypeOfRole: @TypeOfRole, LanguageName: "@LanguageName", StateID: StateID }
                }).then(function (response) {
                    $scope.District = response.data;
                    if ($scope.District.length > 0) {
                    $scope.districttag = true;
                }
                },
                function (response) {
                    alert("No result found");
                });
        }
        $scope.GetBlock = function (DistrictID) {
            $http({
                method: 'POST',
                url: '@Url.Action("GetBlockList", "AGROMET")',
                headers: {
                    'Content-Type': "Application/Json"
                },
                data: { TypeOfRole: @TypeOfRole, LanguageName: "@LanguageName", DistrictID: DistrictID }
                }).then(function (response) {
                $scope.Block = response.data;
                    if ($scope.Block.length > 0) {
                        $scope.blocktag = true;
                    }
                },
                function (response) {
                    alert("No result found");
             });
        }
        $scope.GetBlockById = function () {
            $http({
                method: 'POST',
                url: '@Url.Action("GetBlockList", "AGROMET")',
                headers: {
                    'Content-Type': "Application/Json"
                },
                data: { TypeOfRole: @TypeOfRole, LanguageName: "@LanguageName", DistrictID: this.DistrictID }
                }).then(function (response) {
                $scope.Block = response.data;
                    if ($scope.Block.length > 0) {
                        $scope.blocktag = true;
                    }
                },
                function (response) {
                    alert("No result found");
             });
        }
        $scope.GetCrop = function (TypeOfRole) {
            $http({
                method: 'POST',
                url: '@Url.Action("GetCropList", "AGROMET")',
                headers: {
                    'Content-Type': "Application/Json"
                },
                data: { TypeOfRole: TypeOfRole, LanguageName: "@LanguageName" }
                }).then(function (response) {
                    $scope.Crop = response.data;
                    if ($scope.Crop.length > 0) {
                        $scope.croptag = true;
                    }
                },
                function (response) {
                    alert("No result found");
                });
        }
        $scope.GetLanguage = function () {
            $http({
                method: 'POST',
                url: '@Url.Action("GetLanguageList", "AGROMET")',
                headers: {
                    'Content-Type': "Application/Json"
                },
                data: { LanguageTypeId: 0, LanguageTypeName: "@LanguageName" }
                }).then(function (response) {
                    $scope.Language = response.data;
                    if ($scope.Language.length > 0) {
                        $scope.languagetag = true;
                    }
                },
                function (response) {
                    alert("No result found");
                });
        }
    });
    </script>
    <script>
        var $fileUpload = $("#cafile"),
            $audiofile = $("#audiofile"),
            $list = $('#imglist'),
            thumbsArray = [],
            maxUpload = 5;

        // READ FILE + CREATE IMAGE
        function read(f) {
            return function (e) {
                var base64 = e.target.result;
                var $img = $('<img/>', {
                    src: base64,
                    title: encodeURIComponent(f.name), //( escape() is deprecated! )
                    "class": "thumb"
                });
                var $thumbParent = $("<span/>", { html: $img, "class": "thumbParent" }).append('<span>&emsp;<span/>');
                thumbsArray.push(base64); // Push base64 image into array or whatever.
                $list.append($thumbParent);
            };
        }

        // HANDLE FILE/S UPLOAD
        function handleFileSelect(e) {
            e.preventDefault(); // Needed?
            var files = e.target.files;
            var len = files.length;
            if (len > maxUpload || thumbsArray.length >= maxUpload) {
                return alert("you can upload only 5 images");
            }
            for (var i = 0; i < len; i++) {
                var f = files[i];
                var ftype = files[i].type;
                if (!ftype.match('image.*')) {
                    $list.empty();
                    $fileUpload.val("");
                    thumbsArray = [];
                    alert("Please select Image file.")
                    return false;
                }// Only images allowed
                var reader = new FileReader();
                reader.onload = read(f); // Call read() function
                reader.readAsDataURL(f);
            }
        }
        $fileUpload.click(function () {
            $list.empty();
            $fileUpload.val("");
            thumbsArray = [];
        })
        $fileUpload.change(function (e) {
            handleFileSelect(e);
        });

        $list.on('click', '.remove_thumb', function () {
            var $removeBtns = $('.remove_thumb'); // Get all of them in collection
            var idx = $removeBtns.index(this);   // Exact Index-from-collection
            var files = jQuery("#sodfile")[0].files;
            jQuery("#sodfile")[0].files[idx].remove;
            $(this).closest('span.thumbParent').remove(); // Remove tumbnail parent
            thumbsArray.splice(idx, 1); // Remove from array
        });

        $audiofile.change(function (e) {
            var audio = e.target.files;
            var len = audio.length;
            for (var i = 0; i < len; i++) {
                var f = audio[i];
                var ftype = audio[i].type;
                if (!ftype.match('audio.*')) {
                    $audiofile.val("");
                    alert("Please select audio file.")
                    return false;
                }// Only audio allowed

            }
        });
    </script>
