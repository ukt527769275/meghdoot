    <script>
        function getcategory(){
        debugger;
            var ProvinceIndex = $("#cropid_crop").prop('selectedIndex');
            var ddlVar = $("#categoryid");
        if (ProvinceIndex == 0) {
            $('#categoryid').empty();
            return false;
        }
        else {
            var ProvinceValue = $("#cropid_crop").val();
            $('#categoryid').empty();
            var myUrl = "/AGROMET/GetCategoryByCropName";
            var postData = {
                CropID: ProvinceValue, LanguageName : "@LanguageName"
            };
            //addAntiForgeryToken(postData);
            $.ajax({
                cache: false,
                type: "POST",
                url: '@Url.Action("GetCategoryByCropName", "AGROMET")',

                async: false,
                data: postData,

                success: function (response) {
                    ddlVar.html('');
                    $("#categoryid").append($("<option></option>").val(0).html("--Select--"));

                    if (response.length > 0) {
                        debugger;
                        for (i = 0; i < response.length; i++) {
                            var ID = parseInt(response[i].Value);
                            var Title = response[i].Text;
                            //alert(Title);
                            $("#categoryid").append($("<option></option>").val(ID).html(Title));
                        }
                    }
                },
                error: function (result) {
                    debugger;
                    alert("error");
                }
            });
        }
    }
